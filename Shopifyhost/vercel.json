{
  "version": 2,
  "builds": [
    {
      "src": "api/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "api/server.js"
    }
  ],
  "env": {
    "SHOPIFY_SHOP": "fakestore-practice1.myshopify.com",
    "SUPABASE_URL": "https://ojeipoemzriiykfajkdh.supabase.co",
    "FRONTEND_URL": "https://ceymox-internship.vercel.app"
  }
}