{
  "version": 2,
  "builds": [
    { "src": "api/server.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/products", "dest": "/api/server.js" },
    { "src": "/products-in-db", "dest": "/api/server.js" },
    { "src": "/add-to-db/(.*)", "dest": "/api/server.js" },
    { "src": "/remove/(.*)", "dest": "/api/server.js" },
    { "src": "/edit/(.*)", "dest": "/api/server.js" },
    { "src": "/debug/(.*)", "dest": "/api/server.js" },
    { "src": "/customers", "dest": "/api/server.js" },
    { "src": "/orders", "dest": "/api/server.js" },
    { "src": "/shop", "dest": "/api/server.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
